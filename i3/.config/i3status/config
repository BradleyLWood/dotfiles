general {
        colors = true
        interval = 5
        color_good = "#a3be8c"
        color_bad = "#BF616A"
        color_degraded = "#4c566a"
}

order += "volume master"
order += "wireless wlo1"
order += "disk /"
order += "tztime local"

volume master {
        format = "´®¢ %volume"
        format_muted = "´¬Ç (%volume)"
        device = "pulse:1"
}

